# Copy this file to .env.local and fill in real values before running `npm run dev`.
# The app validates these at boot and will refuse to start if anything is missing or invalid.

# Public URL of your Supabase project (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-project-url>

# Public anon key for Supabase client-side access (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Anthropic API key for Claude (server-side only — never exposed to the browser).
ANTHROPIC_API_KEY=<your-anthropic-api-key>
